# Polymarket CLOB 下单签名私钥。
PRIVATE_KEY=
# Dashboard 监听地址，默认 0.0.0.0:3000。
DASHBOARD_ADDR=0.0.0.0:3000

# 数据库存储路径
SQLITE_PATH=data/runtime/events.sqlite3

# 订阅并交易的加密资产列表，逗号分隔。
SYMBOLS=btc,eth,sol,xrp
# 运行时启用的周期列表，逗号分隔。
INTERVALS=5m,15m
# 正常放行候选使用的固定下单美元金额。
ALLOW_ORDER_USDC=5.0
# 当候选信号通过，但背景过滤判定只能降档参与时，使用的较小固定下单美元金额。
REDUCE_ORDER_USDC=4.0
# `0` 或不填表示继续走实时 Polymarket 报价；大于 `0` 时固定按该价格挂单。
CRYPTO_REVERSAL_ORDER_PRICE=0.52
